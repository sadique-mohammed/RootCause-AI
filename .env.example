# ============================================
# RootCause AI — Environment Configuration
# ============================================
# Copy this file to .env and fill in real values.

# ---------- Target VM ----------
TARGET_HOST=192.168.64.2
TARGET_USER=ubuntu
TARGET_SSH_KEY=~/.ssh/id_rsa
# TARGET_PASSWORD=  # fallback if no SSH key

# ---------- Database ----------
DATABASE_URL=postgresql+asyncpg://rootcause:rootcause@localhost:5432/rootcause_db

# ---------- AI / LLM ----------
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Local LLM via Ollama (default for dev)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# LiteLLM provider routing
LITELLM_PROVIDER=ollama  # options: openai, ollama

# ---------- App ----------
APP_ENV=development
LOG_LEVEL=DEBUG
MAX_TOOL_ITERATIONS=15
DIAGNOSIS_TIMEOUT_SECONDS=120
